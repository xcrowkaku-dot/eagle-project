{
  "_comment": "Copy this file to config.json and fill in real values.",
  "prefix": "-",
  "credentials": {
    "_comment": "Optional email/password for auto re-login.",
    "email": "",
    "password": ""
  },
  "appStatePath": "./appstate.json",
  "bot": {
    "name": "Eagle",
    "version": "2.1.0",
    "adminIDs": [
      "YOUR_FACEBOOK_USER_ID"
    ],
    "language": "en"
  },
  "features": {
    "autoSaveAppState": true,
    "autoSaveIntervalMs": 900000,
    "greetNewMembers": false,
    "farewellMembers": false,
    "antiSpam": true,
    "antiSpamCooldownMs": 3000,
    "logMessages": true
  },
  "humanSimulator": {
    "_comment": "Human simulation — makes the account look like a real person to Facebook.",
    "enabled": true,
    "presenceIntervalMs": 300000,
    "typingIntervalMs": 480000,
    "readIntervalMs": 180000,
    "jitterMs": 30000,
    "maxTypingMs": 4000,
    "maxGroupsPerCycle": 3
  },
  "dashboard": {
    "_comment": "Set a STRONG apiKey (min 32 chars, uppercase, numbers, symbols).",
    "apiKey": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_32+",
    "port": 3001
  },
  "messages": {
    "greet": "Welcome to the group, {name}! 👋",
    "farewell": "Goodbye, {name}! We'll miss you. 👋",
    "commandNotFound": "Unknown command '{cmd}'. Type {prefix}help for a list of commands.",
    "errorOccurred": "⚠️ An error occurred while running that command.",
    "botRestarted": "🤖 Bot session has been restored successfully!"
  },
  "loginOptions": {
    "online": true,
    "selfListen": false,
    "listenEvents": true,
    "listenTyping": false,
    "autoMarkRead": true,
    "autoMarkDelivery": false,
    "autoReconnect": true,
    "simulateTyping": true,
    "forceLogin": false,
    "maxConcurrentRequests": 5,
    "maxRequestsPerMinute": 40,
    "requestCooldownMs": 60000
  }
}
